{
  "name": "policywright",
  "version": "0.1.0",
  "description": "Synthesize a least-privilege OpenZeppelin smart-account authorization from a recorded Soroban transaction, with a dry-run verifier.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "demo": "tsx src/demo.ts",
    "cli": "tsx src/cli.ts",
    "synth": "tsx src/cli.ts synth",
    "simulate": "tsx src/cli.ts simulate",
    "record": "tsx src/cli.ts record",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^15.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.20",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.8.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^3.2.6"
  }
}
